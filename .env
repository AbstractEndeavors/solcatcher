# ═══════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════

# PostgreSQL Connection
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=solcatcher
POSTGRES_PASSWORD=solcatcher123!!!456
POSTGRES_DB=solcatcher
POSTGRES_SSL=false

# Connection Pool Sizing
# CRITICAL: Based on observed load (8 concurrent handlers + headroom)
# Rule: max >= min, maxConcurrent <= max
DB_POOL_MAX=16              # Maximum connections in pool
DB_POOL_MIN=10              # Minimum idle connections maintained
DB_MAX_CONCURRENT=12        # Semaphore limit (prevents pool exhaustion)

# Connection Timeouts (milliseconds)
DB_CONNECTION_TIMEOUT_MS=10000    # Time to wait for pool connection
DB_IDLE_TIMEOUT_MS=30000          # Idle connection eviction time
DB_STATEMENT_TIMEOUT_MS=30000     # Query execution timeout

# Circuit Breaker Configuration
DB_CIRCUIT_BREAKER=true              # Enable circuit breaker
DB_CB_FAILURE_THRESHOLD=5            # Failures before opening circuit
DB_CB_SUCCESS_THRESHOLD=2            # Successes to close circuit
DB_CB_TIMEOUT_MS=30000               # Time window for failures
DB_CB_RETRY_DELAY_MS=5000            # Delay before HALF_OPEN attempt

# Semaphore Configuration
DB_SEMAPHORE=true                    # Enable connection semaphore
DB_SEMAPHORE_TIMEOUT_MS=15000        # Max wait time in queue
DB_SEMAPHORE_METRICS=false           # Log semaphore metrics

# Monitoring
DB_LOG_POOL_STATS=false              # Periodic pool stats logging
DB_STATS_INTERVAL_MS=60000           # Stats logging interval
DB_POOL_DEBUG=false                  # Enable pg-pool debug logging

# ═══════════════════════════════════════════════════════════
# RABBITMQ CONFIGURATION
# ═══════════════════════════════════════════════════════════
DB_POOL_MAX=16
DB_POOL_MIN=10
DB_CONNECTION_TIMEOUT_MS=10000
PREFETCH_COUNT=5


# Consumer Concurrency Control
# CRITICAL: Limits message prefetch per consumer
PREFETCH_COUNT=5                     # Messages to prefetch per consumer
MAX_CONSUMER_CONCURRENCY=8           # Max concurrent handler executions

# Consumer Retry Configuration
CONSUMER_RETRY_DELAY_MS=1000         # Initial retry delay
CONSUMER_MAX_RETRIES=3               # Max retry attempts

# ═══════════════════════════════════════════════════════════
# SOLANA RPC CONFIGURATION
# ═══════════════════════════════════════════════════════════

DB_MAX_CONCURRENT=25
DB_SEMAPHORE_TIMEOUT_MS=30000

